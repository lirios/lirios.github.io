---
import SiteLayout from '@layouts/SiteLayout.astro';
---

<SiteLayout title="Not Found" variant="plain">
  <section class="section-band">
    <div class="section-inner prose" style="text-align: center; padding: 56px 0;">
      <md-icon style="font-size: 160px; color: var(--md-sys-color-error);">warning</md-icon>
      <h1>404</h1>
      <p>You may have mistyped the URL, or the page has been removed.</p>
      <md-filled-button href="/">Go Home</md-filled-button>
    </div>
  </section>
</SiteLayout>
