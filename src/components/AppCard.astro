---
interface Props {
  title: string;
  description: string;
  image: string;
  href?: string;
  repo?: string;
  download?: string;
}

const { title, description, image, href, repo, download } = Astro.props;
---

<article class="card app-card">
  <md-elevation></md-elevation>
  <img src={image} alt={`${title} screenshot`} loading="lazy" />
  <div class="card-body">
    <h3>{title}</h3>
    <p>{description}</p>
  </div>
  <div class="card-actions">
    {href && <md-filled-tonal-button href={href}>Learn More</md-filled-tonal-button>}
    {repo && (
      <md-icon-button href={repo} aria-label={`${title} source code`}>
        <md-icon>code</md-icon>
      </md-icon-button>
    )}
    {download && (
      <md-icon-button href={download} aria-label={`Download ${title}`}>
        <md-icon>download</md-icon>
      </md-icon-button>
    )}
  </div>
</article>
